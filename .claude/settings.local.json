{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "command": "bash .claude/hooks/auto-build-check.sh \"$CLAUDE_FILE_PATH\"",
        "timeout": 120000
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git commit'; then bash .claude/hooks/pre-commit-check.sh; fi",
        "timeout": 30000
      }
    ]
  }
}
